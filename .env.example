# ─── REQUIRED ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Railway: copy from Railway dashboard → Variables)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/beagvs

# A long, random secret used to sign session cookies.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_with_a_very_long_random_string_at_least_64_chars

# Node environment (set to "production" on Railway)
NODE_ENV=production

# ─── OPTIONAL — Replit Auth (only needed when running on Replit) ──────────────
# Leave these unset on Railway. The app will use email/password auth only.
# REPLIT_DOMAINS=your-repl-name.replit.app
# REPL_ID=your-repl-id
# ISSUER_URL=https://replit.com/oidc

# ─── OPTIONAL — File / Object Storage ────────────────────────────────────────
# Required only if you use KYC document uploads or object storage.
# On Railway, point these to a Google Cloud Storage bucket you create manually.
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-gcs-bucket-name
# PRIVATE_OBJECT_DIR=/your-bucket/private
# PUBLIC_OBJECT_SEARCH_PATHS=/your-bucket/public
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
